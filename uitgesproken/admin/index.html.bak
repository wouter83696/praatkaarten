<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Uitgesproken — Beheer</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --teal:      #4f8e9e;
  --teal-dark: #3a717f;
  --teal-pale: #e8f4f6;
  --ink:       #1a1a2e;
  --ink-mid:   rgba(26,26,46,0.65);
  --ink-soft:  rgba(26,26,46,0.40);
  --bg:        #f3f6f7;
  --surface:   #ffffff;
  --border:    rgba(26,26,46,0.10);
  --sidebar-w: 240px;
  --red:       #d94f4f;
  --green:     #3a9a6e;
}

html, body { height: 100%; font-family: 'IBM Plex Sans', system-ui, sans-serif; background: var(--bg); color: var(--ink); font-size: 14px; }

/* ── SETUP SCREEN ── */
#setupScreen {
  display: flex; align-items: center; justify-content: center;
  min-height: 100vh; padding: 24px;
}
.setupCard {
  background: var(--surface); border-radius: 16px;
  box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  padding: 40px; width: 100%; max-width: 420px;
}
.setupLogo { display: flex; align-items: center; gap: 10px; margin-bottom: 28px; }
.setupLogoIcon {
  width: 36px; height: 36px; border-radius: 10px;
  background: var(--teal); display: flex; align-items: center; justify-content: center;
}
.setupLogoIcon svg { width: 18px; height: 18px; stroke: #fff; }
.setupCard h1 { font-size: 20px; font-weight: 600; margin-bottom: 4px; }
.setupCard p { color: var(--ink-mid); font-size: 13px; line-height: 1.6; margin-bottom: 24px; }
.setupCard a { color: var(--teal); }

.field { margin-bottom: 16px; }
.field label { display: block; font-size: 12px; font-weight: 500; color: var(--ink-mid); margin-bottom: 6px; letter-spacing: 0.04em; text-transform: uppercase; }
.field input {
  width: 100%; padding: 10px 12px; border: 1px solid var(--border);
  border-radius: 8px; font-family: inherit; font-size: 14px;
  background: var(--bg); color: var(--ink); outline: none;
  transition: border-color 0.15s;
}
.field input:focus { border-color: var(--teal); }

.btnPrimary {
  width: 100%; padding: 12px; background: var(--teal); color: #fff;
  border: none; border-radius: 10px; font-family: inherit; font-size: 14px;
  font-weight: 500; cursor: pointer; transition: background 0.15s;
}
.btnPrimary:hover { background: var(--teal-dark); }
.btnPrimary:disabled { opacity: 0.5; cursor: default; }

.setupNote {
  margin-top: 20px; padding: 14px; background: var(--teal-pale);
  border-radius: 8px; font-size: 12.5px; color: var(--teal-dark); line-height: 1.6;
}
.setupNote ol { padding-left: 16px; margin-top: 8px; }
.setupNote li { margin-bottom: 4px; }

/* ── MAIN LAYOUT ── */
#mainScreen { display: flex; height: 100vh; overflow: hidden; }

/* Sidebar */
.sidebar {
  width: var(--sidebar-w); flex-shrink: 0;
  background: var(--surface); border-right: 1px solid var(--border);
  display: flex; flex-direction: column; overflow: hidden;
}
.sidebarHeader {
  padding: 18px 16px 14px; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; gap: 8px;
}
.sidebarLogo {
  width: 28px; height: 28px; border-radius: 8px; background: var(--teal);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.sidebarLogo svg { width: 14px; height: 14px; stroke: #fff; }
.sidebarTitle { font-size: 13.5px; font-weight: 600; color: var(--ink); }
.sidebarSub { font-size: 11px; color: var(--ink-soft); margin-top: 1px; }

.sidebarSection { padding: 10px 8px 4px; }
.sidebarLabel {
  font-size: 10.5px; font-weight: 500; color: var(--ink-soft);
  letter-spacing: 0.07em; text-transform: uppercase;
  padding: 0 8px; margin-bottom: 4px;
}

.setItem {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 8px 8px 10px; border-radius: 8px; cursor: pointer;
  transition: background 0.12s; width: 100%; text-align: left;
  border: none; background: transparent; font-family: inherit; font-size: 13px;
}
.setItem:hover { background: var(--bg); }
.setItem.active { background: var(--teal-pale); color: var(--teal-dark); }
.setItem.active .setItemDot { background: var(--teal); }
.setItemDot {
  width: 8px; height: 8px; border-radius: 50%; background: var(--border);
  flex-shrink: 0; margin-right: 2px;
}
.setItemName { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.setItemHandle { cursor: grab; color: var(--ink-soft); font-size: 12px; opacity: 0; }
.setItem:hover .setItemHandle { opacity: 1; }

.sidebarFlex { flex: 1; overflow-y: auto; }
.sidebarFlex::-webkit-scrollbar { width: 4px; }
.sidebarFlex::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

.addSetBtn {
  display: flex; align-items: center; gap: 6px;
  padding: 8px 10px; border-radius: 8px; cursor: pointer;
  background: transparent; border: 1px dashed var(--border);
  color: var(--ink-mid); font-family: inherit; font-size: 13px;
  width: calc(100% - 16px); margin: 4px 8px; transition: all 0.12s;
}
.addSetBtn:hover { background: var(--bg); border-color: var(--teal); color: var(--teal); }

.sidebarFooter {
  padding: 10px 8px; border-top: 1px solid var(--border);
}
.settingsBtn {
  display: flex; align-items: center; gap: 6px;
  padding: 8px 10px; border-radius: 8px; cursor: pointer;
  background: transparent; border: none; color: var(--ink-soft);
  font-family: inherit; font-size: 12.5px; width: 100%; text-align: left;
  transition: all 0.12s;
}
.settingsBtn:hover { background: var(--bg); color: var(--ink); }

/* Content area */
.content {
  flex: 1; overflow-y: auto; display: flex; flex-direction: column;
}
.content::-webkit-scrollbar { width: 6px; }
.content::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

/* Top bar */
.topBar {
  padding: 16px 28px 0; display: flex; align-items: center;
  justify-content: space-between; flex-shrink: 0;
}
.topBarTitle { font-size: 17px; font-weight: 600; }
.topBarSub { font-size: 12px; color: var(--ink-soft); margin-top: 2px; }

.topBarActions { display: flex; gap: 8px; align-items: center; }

.btnSave {
  padding: 8px 18px; background: var(--teal); color: #fff;
  border: none; border-radius: 8px; font-family: inherit; font-size: 13px;
  font-weight: 500; cursor: pointer; transition: background 0.15s;
}
.btnSave:hover { background: var(--teal-dark); }
.btnSave:disabled { opacity: 0.45; cursor: default; }
.btnSave.saving { background: var(--teal-dark); }

.btnDelete {
  padding: 8px 14px; background: transparent; color: var(--red);
  border: 1px solid rgba(217,79,79,0.25); border-radius: 8px;
  font-family: inherit; font-size: 13px; cursor: pointer; transition: all 0.15s;
}
.btnDelete:hover { background: rgba(217,79,79,0.06); }

/* Tabs */
.tabs {
  display: flex; gap: 2px; padding: 20px 28px 0; flex-shrink: 0;
}
.tab {
  padding: 7px 14px; border-radius: 7px 7px 0 0; cursor: pointer;
  font-size: 13px; color: var(--ink-mid); border: 1px solid transparent;
  border-bottom: none; background: transparent; font-family: inherit;
  transition: all 0.12s;
}
.tab:hover { color: var(--ink); background: var(--surface); }
.tab.active {
  color: var(--teal-dark); background: var(--surface);
  border-color: var(--border); font-weight: 500;
}

/* Tab content */
.tabContent {
  flex: 1; padding: 0 28px 28px;
  border-top: 1px solid var(--border);
  background: var(--surface); margin: 0 28px;
  border-radius: 0 8px 8px 8px; overflow: visible;
}

.panel { padding: 20px 0; }

/* Form elements */
.formRow { margin-bottom: 18px; }
.formLabel {
  display: block; font-size: 12px; font-weight: 500;
  color: var(--ink-mid); margin-bottom: 7px;
  letter-spacing: 0.03em; text-transform: uppercase;
}
.formInput, .formTextarea, .formSelect {
  width: 100%; padding: 9px 12px; border: 1px solid var(--border);
  border-radius: 8px; font-family: inherit; font-size: 13.5px;
  background: var(--bg); color: var(--ink); outline: none;
  transition: border-color 0.15s;
}
.formInput:focus, .formTextarea:focus, .formSelect:focus { border-color: var(--teal); }
.formTextarea { resize: vertical; min-height: 80px; line-height: 1.55; }

.formGrid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.formHint { font-size: 11.5px; color: var(--ink-soft); margin-top: 5px; line-height: 1.5; }

.colorRow { display: flex; align-items: center; gap: 8px; }
.colorRow input[type="color"] {
  width: 36px; height: 36px; padding: 2px; border: 1px solid var(--border);
  border-radius: 6px; cursor: pointer; background: var(--bg); flex-shrink: 0;
}
.colorRow .formInput { flex: 1; }

/* Section heading */
.sectionHead {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18px 0 12px; border-bottom: 1px solid var(--border); margin-bottom: 14px;
}
.sectionHead h3 { font-size: 14px; font-weight: 600; }

.btnSmall {
  padding: 5px 12px; border-radius: 7px; font-family: inherit; font-size: 12px;
  font-weight: 500; cursor: pointer; transition: all 0.12s;
}
.btnSmall.teal { background: var(--teal-pale); color: var(--teal-dark); border: none; }
.btnSmall.teal:hover { background: #d0eaee; }
.btnSmall.grey { background: var(--bg); color: var(--ink-mid); border: 1px solid var(--border); }
.btnSmall.grey:hover { border-color: var(--teal); color: var(--teal); }
.btnSmall.red { background: rgba(217,79,79,0.08); color: var(--red); border: none; }
.btnSmall.red:hover { background: rgba(217,79,79,0.15); }

/* Themes list */
.themeList { display: flex; flex-direction: column; gap: 8px; }
.themeRow {
  display: flex; align-items: center; gap: 8px;
  background: var(--bg); border-radius: 8px; padding: 10px 12px;
  border: 1px solid var(--border);
}
.themeRowHandle { cursor: grab; color: var(--ink-soft); font-size: 14px; flex-shrink: 0; }
.themeRowKey {
  width: 120px; flex-shrink: 0; font-size: 12px; font-weight: 500;
  color: var(--ink-mid); font-family: monospace;
}
.themeRowLabel { flex: 1; }
.themeRowLabel input { border: none; background: transparent; font-family: inherit; font-size: 13px; color: var(--ink); width: 100%; outline: none; padding: 2px 4px; border-radius: 4px; }
.themeRowLabel input:focus { background: white; }

/* Questions */
.themeSection { margin-bottom: 28px; }
.themeSectionHead {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 14px; background: var(--teal-pale); border-radius: 8px 8px 0 0;
  border: 1px solid rgba(79,142,158,0.18);
}
.themeSectionHead h4 { font-size: 13px; font-weight: 600; color: var(--teal-dark); }
.qList {
  border: 1px solid rgba(79,142,158,0.18); border-top: none;
  border-radius: 0 0 8px 8px; overflow: hidden;
}
.qRow {
  display: flex; align-items: flex-start; gap: 8px;
  padding: 10px 12px; border-bottom: 1px solid var(--border);
  background: white;
}
.qRow:last-child { border-bottom: none; }
.qNum { width: 22px; flex-shrink: 0; color: var(--ink-soft); font-size: 12px; padding-top: 8px; text-align: right; }
.qInput {
  flex: 1; border: none; background: transparent; font-family: inherit;
  font-size: 13px; color: var(--ink); outline: none; padding: 6px 8px;
  border-radius: 5px; resize: none; min-height: 36px; line-height: 1.5;
}
.qInput:focus { background: var(--bg); }
.qDel { flex-shrink: 0; cursor: pointer; color: var(--ink-soft); padding: 6px; border: none; background: none; border-radius: 5px; transition: all 0.12s; font-size: 16px; line-height: 1; }
.qDel:hover { color: var(--red); background: rgba(217,79,79,0.08); }

/* Uitleg editor */
.uitlegSection { margin-bottom: 18px; }
.uitlegLabel {
  font-size: 12px; font-weight: 500; color: var(--teal-dark);
  margin-bottom: 6px; letter-spacing: 0.03em;
}

/* Welcome screen */
.welcome {
  flex: 1; display: flex; align-items: center; justify-content: center;
  flex-direction: column; text-align: center; padding: 40px; color: var(--ink-mid);
}
.welcome svg { opacity: 0.25; margin-bottom: 16px; }
.welcome h2 { font-size: 16px; font-weight: 500; color: var(--ink); margin-bottom: 8px; }
.welcome p { font-size: 13px; line-height: 1.6; max-width: 340px; }

/* Toast */
.toast {
  position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(80px);
  background: var(--ink); color: white; padding: 10px 20px; border-radius: 10px;
  font-size: 13px; font-weight: 500; z-index: 1000;
  transition: transform 0.25s ease; box-shadow: 0 4px 20px rgba(0,0,0,0.25);
  white-space: nowrap;
}
.toast.show { transform: translateX(-50%) translateY(0); }
.toast.green { background: var(--green); }
.toast.red { background: var(--red); }

/* New set modal */
.overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.3);
  display: flex; align-items: center; justify-content: center; z-index: 500; padding: 24px;
}
.modal {
  background: white; border-radius: 14px; padding: 28px;
  width: 100%; max-width: 380px; box-shadow: 0 8px 40px rgba(0,0,0,0.15);
}
.modal h3 { font-size: 16px; font-weight: 600; margin-bottom: 6px; }
.modal p { font-size: 13px; color: var(--ink-mid); margin-bottom: 20px; line-height: 1.5; }
.modalActions { display: flex; gap: 8px; margin-top: 20px; }
.btnCancel {
  flex: 1; padding: 10px; border: 1px solid var(--border); background: transparent;
  border-radius: 8px; font-family: inherit; font-size: 13px; cursor: pointer;
}
.btnCancel:hover { background: var(--bg); }
.btnConfirm {
  flex: 1; padding: 10px; background: var(--teal); color: white;
  border: none; border-radius: 8px; font-family: inherit; font-size: 13px;
  font-weight: 500; cursor: pointer;
}
.btnConfirm:hover { background: var(--teal-dark); }
.btnConfirmRed {
  flex: 1; padding: 10px; background: var(--red); color: white;
  border: none; border-radius: 8px; font-family: inherit; font-size: 13px;
  font-weight: 500; cursor: pointer;
}

/* Loader */
.spinner {
  display: inline-block; width: 16px; height: 16px;
  border: 2px solid rgba(255,255,255,0.4); border-top-color: white;
  border-radius: 50%; animation: spin 0.7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

.hidden { display: none !important; }

/* ── KAARTEN TAB ── */
.cardGrid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 14px; padding: 20px 0;
}
.cardTile {
  border: 1px solid var(--border); border-radius: 10px;
  overflow: hidden; background: var(--bg); position: relative;
  transition: border-color 0.15s, box-shadow 0.15s;
}
.cardTile:hover { border-color: var(--teal); box-shadow: 0 2px 12px rgba(79,142,158,0.15); }
.cardTile input[type="file"] { display: none; }
.cardPreview {
  width: 100%; aspect-ratio: 85 / 55; display: flex;
  align-items: center; justify-content: center;
  background: white; overflow: hidden; position: relative;
}
.cardPreview img { width: 100%; height: 100%; object-fit: contain; display: block; }
.cardPreviewEmpty {
  width: 100%; aspect-ratio: 85 / 55; display: flex; flex-direction: column;
  align-items: center; justify-content: center; background: var(--bg);
  color: var(--ink-soft); font-size: 11px; gap: 6px;
}
.cardTileLabel {
  padding: 8px 10px; font-size: 12px; font-weight: 500;
  color: var(--ink-mid); border-top: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between; gap: 6px;
}
.cardUploadBtn {
  font-size: 11px; padding: 3px 8px; border-radius: 5px;
  background: var(--teal-pale); color: var(--teal-dark);
  border: none; cursor: pointer; font-family: inherit; white-space: nowrap;
  transition: background 0.12s;
}
.cardUploadBtn:hover { background: #d0eaee; }
.cardUploading {
  position: absolute; inset: 0; background: rgba(255,255,255,0.88);
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; color: var(--teal-dark); gap: 8px; z-index: 2;
}
.cardSectionSub { font-size: 12px; color: var(--ink-soft); margin-bottom: 16px; line-height: 1.55; }
.dropZone {
  border: 2px dashed var(--border); border-radius: 10px;
  padding: 24px; text-align: center; color: var(--ink-soft);
  font-size: 13px; line-height: 1.6; cursor: pointer;
  transition: all 0.15s; margin-bottom: 8px;
}
.dropZone:hover, .dropZone.over { border-color: var(--teal); color: var(--teal-dark); background: var(--teal-pale); }
.dropZone svg { display: block; margin: 0 auto 10px; opacity: 0.35; }
/* ── STIJL / TEMPLATE PICKER TAB ── */
.templateGrid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 14px; padding: 20px 0 4px;
}
.templateCard {
  border: 2px solid var(--border); border-radius: 12px;
  overflow: hidden; cursor: pointer; background: white;
  transition: border-color 0.15s, box-shadow 0.15s, transform 0.1s;
  position: relative;
}
.templateCard:hover { border-color: var(--teal); box-shadow: 0 3px 16px rgba(79,142,158,0.15); transform: translateY(-1px); }
.templateCard.selected { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(79,142,158,0.18); }
.templateCard.selected .templateBadge { opacity: 1; }
.templateBadge {
  position: absolute; top: 8px; right: 8px;
  background: var(--teal); color: white; border-radius: 50%;
  width: 22px; height: 22px; display: flex; align-items: center; justify-content: center;
  font-size: 12px; opacity: 0; transition: opacity 0.15s; font-weight: 600;
}
.templateThumb {
  width: 100%; aspect-ratio: 4/3; background: var(--bg);
  display: flex; align-items: flex-end; justify-content: center;
  overflow: hidden; padding: 14px 14px 0;
}
.templateThumb svg { width: 100%; max-width: 180px; }
.templateInfo { padding: 10px 12px 12px; border-top: 1px solid var(--border); background: white; }
.templateName { font-size: 13px; font-weight: 600; margin-bottom: 3px; }
.templateDesc { font-size: 11.5px; color: var(--ink-mid); line-height: 1.5; }
.templateSectionLabel {
  font-size: 11px; font-weight: 500; color: var(--ink-soft);
  letter-spacing: 0.07em; text-transform: uppercase;
  margin: 22px 0 2px;
}
.templateSectionLabel:first-child { margin-top: 6px; }
.colorRow2 { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 8px; margin-bottom: 6px; }
.colorSwatch {
  width: 30px; height: 30px; border-radius: 50%; cursor: pointer;
  border: 2px solid transparent; transition: all 0.12s;
  flex-shrink: 0;
}
.colorSwatch:hover { transform: scale(1.12); }
.colorSwatch.selected { border-color: var(--ink); box-shadow: 0 0 0 2px white, 0 0 0 4px var(--ink); }
.colorPickerRow { display: flex; align-items: center; gap: 8px; margin-top: 10px; }
.colorPickerRow label { font-size: 12px; color: var(--ink-mid); }
/* ── KAART-KOPPELING ── */
.cardTileLinked {
  position: absolute; bottom: 36px; right: 0; left: 0;
  display: flex; align-items: center; justify-content: center;
}
.cardLinkBadge {
  background: rgba(26,26,46,0.62); color: rgba(255,255,255,0.92);
  font-size: 10px; padding: 2px 7px; border-radius: 10px;
  white-space: nowrap; max-width: 90%; overflow: hidden; text-overflow: ellipsis;
  backdrop-filter: blur(4px);
}
.cardLinkBtn {
  font-size: 10.5px; padding: 2px 8px; border-radius: 5px;
  background: var(--teal-pale); color: var(--teal-dark);
  border: none; cursor: pointer; font-family: inherit;
  transition: background 0.12s; white-space: nowrap;
}
.cardLinkBtn:hover { background: #d0eaee; }
.cardTile { position: relative; }

/* File picker popup */
.linkPopup {
  position: fixed; z-index: 200;
  background: white; border-radius: 12px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.18);
  border: 1px solid var(--border);
  padding: 12px; min-width: 200px; max-width: 280px;
}
.linkPopupTitle { font-size: 12px; font-weight: 600; color: var(--ink-mid); margin-bottom: 8px; padding-bottom: 6px; border-bottom: 1px solid var(--border); }
.linkPopupList { display: flex; flex-direction: column; gap: 2px; max-height: 260px; overflow-y: auto; }
.linkPopupItem {
  display: flex; align-items: center; gap: 8px; padding: 6px 8px;
  border-radius: 7px; cursor: pointer; transition: background 0.1s;
  border: none; background: transparent; font-family: inherit; text-align: left; width: 100%;
}
.linkPopupItem:hover { background: var(--teal-pale); }
.linkPopupItem.active { background: var(--teal-pale); font-weight: 500; color: var(--teal-dark); }
.linkPopupThumb { width: 36px; height: 24px; border-radius: 3px; overflow: hidden; flex-shrink: 0; background: var(--bg); border: 1px solid var(--border); }
.linkPopupThumb img { width: 100%; height: 100%; object-fit: contain; }
.linkPopupName { font-size: 12px; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.linkPopupActions { display: flex; gap: 6px; margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--border); }
</style>
</head>
<body>

<!-- SETUP SCREEN -->
<div id="setupScreen">
  <div class="setupCard">
    <div class="setupLogo">
      <div class="setupLogoIcon">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      </div>
      <div>
        <div style="font-size:15px;font-weight:600">Uitgesproken</div>
        <div style="font-size:11px;color:var(--ink-soft)">Beheer</div>
      </div>
    </div>

    <h1>Verbinden met GitHub</h1>
    <p>Vul je repository en een Personal Access Token in om kaartensets te beheren.</p>

    <div class="field">
      <label>Repository (eigenaar/naam)</label>
      <input id="inputRepo" type="text" placeholder="jouw-naam/uitgesproken" spellcheck="false">
    </div>
    <div class="field">
      <label>Personal Access Token</label>
      <input id="inputToken" type="password" placeholder="ghp_xxxxxxxxxxxx">
    </div>

    <button class="btnPrimary" onclick="connectGitHub()">Verbinden</button>

    <div class="setupNote">
      <strong>Token aanmaken (1 minuut):</strong>
      <ol>
        <li>Ga naar <a href="https://github.com/settings/tokens/new" target="_blank">github.com/settings/tokens/new</a></li>
        <li>Vul een naam in, kies <em>No expiration</em></li>
        <li>Vink aan: <strong>repo</strong> (alle rechten)</li>
        <li>Klik <em>Generate token</em> en plak hem hier</li>
      </ol>
    </div>
  </div>
</div>

<!-- MAIN SCREEN -->
<div id="mainScreen" class="hidden">
  <aside class="sidebar">
    <div class="sidebarHeader">
      <div class="sidebarLogo">
        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      </div>
      <div>
        <div class="sidebarTitle">Uitgesproken</div>
        <div id="sidebarRepo" class="sidebarSub">—</div>
      </div>
    </div>

    <div class="sidebarFlex">
      <div class="sidebarSection">
        <div class="sidebarLabel">Kaartensets</div>
        <div id="setList"></div>
        <button class="addSetBtn" onclick="showNewSetModal()">
          <span style="font-size:16px;line-height:1">+</span> Nieuwe set
        </button>
      </div>
    </div>

    <div class="sidebarFooter">
      <button class="settingsBtn" onclick="disconnectGitHub()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Uitloggen
      </button>
    </div>
  </aside>

  <main class="content" id="mainContent">
    <div class="welcome">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      <h2>Selecteer een kaartenset</h2>
      <p>Kies een set in de zijbalk om te bewerken, of maak een nieuwe aan.</p>
    </div>
  </main>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<!-- MODAL -->
<div class="overlay hidden" id="modalOverlay">
  <div class="modal" id="modalContent"></div>
</div>

<script>
'use strict';

// ── STATE ──────────────────────────────────────────────────────
var S = {
  repo: '',
  token: '',
  sets: [],       // from index.json
  indexSha: '',   // sha of index.json
  activeId: null,
  activeData: {}, // { meta, questions, uitleg, intro, metaSha, questionsSha, uitlegSha, introSha }
  dirty: false,
  activeTab: 'algemeen'
};

// ── INIT ──────────────────────────────────────────────────────
(function init() {
  var saved = tryParse(localStorage.getItem('pk_admin_cfg'));
  if (saved && saved.repo && saved.token) {
    S.repo = saved.repo;
    S.token = saved.token;
    document.getElementById('inputRepo').value = S.repo;
    document.getElementById('inputToken').value = S.token;
    loadIndex();
  }
})();

// ── GITHUB API ────────────────────────────────────────────────
function api(path, method, body) {
  method = method || 'GET';
  var opts = {
    method: method,
    headers: {
      'Authorization': 'token ' + S.token,
      'Accept': 'application/vnd.github.v3+json',
      'Content-Type': 'application/json'
    }
  };
  if (body) opts.body = JSON.stringify(body);
  return fetch('https://api.github.com/repos/' + S.repo + path, opts)
    .then(function(r) {
      if (!r.ok) return r.json().then(function(e) { throw new Error(e.message || ('HTTP ' + r.status)); });
      if (r.status === 204) return {};
      return r.json();
    });
}

function getFile(path) {
  return api('/contents/' + path).then(function(res) {
    var text = decodeURIComponent(escape(atob(res.content.replace(/\s/g, ''))));
    return { data: JSON.parse(text), sha: res.sha };
  });
}

function saveFile(path, data, sha, msg) {
  var content = btoa(unescape(encodeURIComponent(JSON.stringify(data, null, 2))));
  var body = { message: msg || ('Update ' + path), content: content };
  if (sha) body.sha = sha;
  return api('/contents/' + path, 'PUT', body);
}

function deleteFile(path, sha, msg) {
  return api('/contents/' + path, 'DELETE', { message: msg || ('Delete ' + path), sha: sha });
}

// ── AUTH ──────────────────────────────────────────────────────
function connectGitHub() {
  var repo = document.getElementById('inputRepo').value.trim();
  var token = document.getElementById('inputToken').value.trim();
  if (!repo || !token) { toast('Vul beide velden in', 'red'); return; }
  S.repo = repo;
  S.token = token;
  localStorage.setItem('pk_admin_cfg', JSON.stringify({ repo: repo, token: token }));
  loadIndex();
}

function disconnectGitHub() {
  localStorage.removeItem('pk_admin_cfg');
  location.reload();
}

// ── LOAD INDEX ────────────────────────────────────────────────
function loadIndex() {
  show('mainScreen'); hide('setupScreen');
  document.getElementById('sidebarRepo').textContent = S.repo;

  getFile('sets/index.json').then(function(res) {
    S.sets = res.data.sets || [];
    S.indexSha = res.sha;
    S.indexData = res.data;
    renderSidebar();
  }).catch(function(e) {
    toast('Fout: ' + e.message, 'red');
    show('setupScreen'); hide('mainScreen');
  });
}

// ── SIDEBAR ───────────────────────────────────────────────────
function renderSidebar() {
  var list = document.getElementById('setList');
  list.innerHTML = '';
  S.sets.forEach(function(s) {
    var btn = document.createElement('button');
    btn.className = 'setItem' + (s.id === S.activeId ? ' active' : '');
    btn.innerHTML =
      '<span class="setItemDot"></span>' +
      '<span class="setItemName">' + esc(s.title || s.id) + '</span>' +
      '<span class="setItemHandle">⠿</span>';
    btn.onclick = function() { loadSet(s.id); };
    list.appendChild(btn);
  });
}

// ── LOAD SET ──────────────────────────────────────────────────
function loadSet(id) {
  S.activeId = id;
  S.dirty = false;
  renderSidebar();

  var content = document.getElementById('mainContent');
  content.innerHTML = '<div class="welcome"><div class="spinner" style="border-color:rgba(79,142,158,0.3);border-top-color:var(--teal)"></div></div>';

  Promise.all([
    getFile('sets/' + id + '/meta.json').catch(function() { return { data: getDefaultMeta(id), sha: null }; }),
    getFile('sets/' + id + '/questions.json').catch(function() { return { data: {}, sha: null }; }),
    getFile('sets/' + id + '/uitleg.json').catch(function() { return { data: {}, sha: null }; }),
    getFile('sets/' + id + '/intro.json').catch(function() { return { data: { slides: [] }, sha: null }; })
  ]).then(function(results) {
    S.activeData = {
      meta: results[0].data,
      metaSha: results[0].sha,
      questions: results[1].data,
      questionsSha: results[1].sha,
      uitleg: results[2].data,
      uitlegSha: results[2].sha,
      intro: results[3].data,
      introSha: results[3].sha
    };
    S.activeTab = 'algemeen';
    renderEditor();
  }).catch(function(e) {
    toast('Fout bij laden: ' + e.message, 'red');
  });
}

// ── EDITOR ────────────────────────────────────────────────────
function renderEditor() {
  var set = S.sets.find(function(s) { return s.id === S.activeId; }) || {};
  var content = document.getElementById('mainContent');
  content.innerHTML =
    '<div class="topBar">' +
      '<div>' +
        '<div class="topBarTitle">' + esc(set.title || S.activeId) + '</div>' +
        '<div class="topBarSub">sets/' + esc(S.activeId) + '</div>' +
      '</div>' +
      '<div class="topBarActions">' +
        '<button class="btnDelete" onclick="confirmDelete()">Verwijderen</button>' +
        '<button class="btnSave" id="saveBtn" onclick="saveSet()">Opslaan</button>' +
      '</div>' +
    '</div>' +
    '<div class="tabs">' +
      ['algemeen', 'stijl', 'kaarten', 'vragen', 'uitleg', 'intro'].map(function(t) {
        return '<button class="tab' + (t === S.activeTab ? ' active' : '') +
          '" onclick="switchTab(\'' + t + '\')">' + tabLabel(t) + '</button>';
      }).join('') +
    '</div>' +
    '<div class="tabContent" id="tabContent"></div>';

  renderTab(S.activeTab);
}

function tabLabel(t) {
  return { algemeen: 'Algemeen', stijl: 'Stijl', kaarten: 'Kaarten', vragen: 'Vragen', uitleg: 'Uitleg', intro: 'Intro' }[t] || t;
}

function switchTab(t) {
  S.activeTab = t;
  document.querySelectorAll('.tab').forEach(function(el) {
    el.classList.toggle('active', el.textContent === tabLabel(t));
  });
  renderTab(t);
}

function renderTab(t) {
  var el = document.getElementById('tabContent');
  if (!el) return;
  if (t === 'algemeen') el.innerHTML = buildAlgemeen();
  else if (t === 'vragen') el.innerHTML = buildVragen();
  else if (t === 'uitleg') el.innerHTML = buildUitleg();
  else if (t === 'stijl') el.innerHTML = buildStijl();
  else if (t === 'kaarten') el.innerHTML = buildKaarten();
  else if (t === 'intro') el.innerHTML = buildIntro();
  initTabEvents(t);
}

// ── TAB: ALGEMEEN ─────────────────────────────────────────────
function buildAlgemeen() {
  var m = S.activeData.meta || {};
  var themes = (m.themes || []);
  return '<div class="panel">' +
    '<div class="formGrid">' +
      formRow('Titel', 'input', 'metaTitle', m.title || '', 'bijv. "Samen onderzoeken"') +
      formRow('Set-ID (slug)', 'input', 'metaId', m.id || S.activeId, '', true) +
    '</div>' +
    formRow('Accentkleur', 'color', 'metaAccent', (m.cssVars || {})['--pk-set-accent'] || '#F3D7A3') +

    '<div class="sectionHead" style="margin-top:24px">' +
      '<h3>Thema\'s</h3>' +
      '<button class="btnSmall teal" onclick="addTheme()">+ Thema toevoegen</button>' +
    '</div>' +
    '<div class="themeList" id="themeList">' +
      themes.map(function(th, i) { return buildThemeRow(th, i); }).join('') +
    '</div>' +
    '<p class="formHint" style="margin-top:10px">Sleep de handgrepen (⠿) om de volgorde aan te passen. De sleutel is de ID die in de vragen-bestanden gebruikt wordt.</p>' +
  '</div>';
}

function buildThemeRow(th, i) {
  return '<div class="themeRow" data-i="' + i + '">' +
    '<span class="themeRowHandle">⠿</span>' +
    '<span class="themeRowKey">' + esc(th.key || '') + '</span>' +
    '<span class="themeRowLabel"><input type="text" value="' + esc(th.label || '') +
      '" oninput="updateThemeLabel(' + i + ',this.value)" placeholder="Label"></span>' +
    '<button class="btnSmall red" onclick="removeTheme(' + i + ')">✕</button>' +
  '</div>';
}

function initTabEvents(t) {
  if (t !== 'algemeen') return;
  document.getElementById('metaTitle').oninput = function() { markDirty(); };
  document.getElementById('metaAccent').oninput = function(e) {
    var hex = document.getElementById('metaAccentHex');
    if (hex) hex.value = e.target.value; markDirty();
  };
  var hexEl = document.getElementById('metaAccentHex');
  if (hexEl) hexEl.oninput = function(e) {
    var picker = document.getElementById('metaAccent');
    var v = e.target.value;
    if (/^#[0-9a-fA-F]{6}$/.test(v)) { picker.value = v; }
    markDirty();
  };
}

function addTheme() {
  var key = prompt('Sleutel voor nieuw thema (bijv. "onderzoeken"):');
  if (!key) return;
  key = key.trim().toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
  if (!key) return;
  S.activeData.meta.themes = S.activeData.meta.themes || [];
  S.activeData.meta.themes.push({ key: key, label: key, card: key + '.svg' });
  if (!S.activeData.questions[key]) S.activeData.questions[key] = [];
  if (!S.activeData.uitleg[key]) S.activeData.uitleg[key] = '';
  markDirty();
  if (S.activeTab === 'algemeen') renderTab('algemeen');
}

function removeTheme(i) {
  if (!confirm('Thema verwijderen? De bijbehorende vragen blijven bewaard in de JSON.')) return;
  S.activeData.meta.themes.splice(i, 1);
  markDirty();
  renderTab('algemeen');
}

function updateThemeLabel(i, val) {
  S.activeData.meta.themes[i].label = val;
  markDirty();
}

// ── TAB: VRAGEN ───────────────────────────────────────────────
function buildVragen() {
  var themes = (S.activeData.meta.themes || []);
  var q = S.activeData.questions || {};
  var html = '<div class="panel">';
  themes.forEach(function(th) {
    var qs = q[th.key] || [];
    html += '<div class="themeSection">' +
      '<div class="themeSectionHead">' +
        '<h4>' + esc(th.label || th.key) + '</h4>' +
        '<button class="btnSmall teal" onclick="addQuestion(\'' + th.key + '\')">+ Vraag</button>' +
      '</div>' +
      '<div class="qList" id="qlist-' + th.key + '">' +
        qs.map(function(card, qi) {
          return '<div class="qRow" data-key="' + th.key + '" data-qi="' + qi + '">' +
            '<span class="qNum">' + (qi + 1) + '</span>' +
            '<textarea class="qInput" rows="1" oninput="updateQ(\'' + th.key + '\',' + qi + ',this.value);autoResize(this)">' +
              esc(card.voorkant || card.q || '') +
            '</textarea>' +
            '<button class="qDel" onclick="removeQ(\'' + th.key + '\',' + qi + ')">✕</button>' +
          '</div>';
        }).join('') +
      '</div>' +
    '</div>';
  });
  html += '</div>';
  return html;
}

function addQuestion(key) {
  if (!S.activeData.questions[key]) S.activeData.questions[key] = [];
  S.activeData.questions[key].push({ voorkant: '', achterkant: '', q: '', back: '' });
  markDirty();
  renderTab('vragen');
  // focus last textarea
  setTimeout(function() {
    var rows = document.querySelectorAll('[data-key="' + key + '"] .qInput');
    if (rows.length) { rows[rows.length - 1].focus(); }
  }, 50);
}

function removeQ(key, qi) {
  S.activeData.questions[key].splice(qi, 1);
  markDirty();
  renderTab('vragen');
}

function updateQ(key, qi, val) {
  var card = S.activeData.questions[key][qi];
  card.voorkant = val;
  card.q = val;
  markDirty();
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = el.scrollHeight + 'px';
}

// ── TAB: UITLEG ───────────────────────────────────────────────
function buildUitleg() {
  var themes = (S.activeData.meta.themes || []);
  var u = S.activeData.uitleg || {};
  var html = '<div class="panel">' +
    '<div class="uitlegSection">' +
      '<div class="uitlegLabel" style="color:var(--ink-mid)">COVER (intro-tekst)</div>' +
      '<textarea class="formTextarea" rows="5" id="uitlegCover" oninput="markDirty()">' +
        esc(u.cover || '') +
      '</textarea>' +
    '</div>';
  themes.forEach(function(th) {
    html +=
      '<div class="uitlegSection">' +
        '<div class="uitlegLabel">' + esc(th.label || th.key) + '</div>' +
        '<textarea class="formTextarea" rows="3" id="uitleg-' + th.key + '" oninput="markDirty()">' +
          esc(u[th.key] || '') +
        '</textarea>' +
      '</div>';
  });
  html += '</div>';
  return html;
}

// ── TAB: INTRO ────────────────────────────────────────────────
function buildIntro() {
  var slides = (S.activeData.intro.slides || []);
  return '<div class="panel">' +
    '<p class="formHint" style="margin-bottom:16px">Intro-slides worden getoond als de gebruiker op ⓘ tikt. Elke slide heeft een titel en een korte omschrijving.</p>' +
    '<div id="introSlides">' +
      slides.map(function(sl, i) { return buildSlideRow(sl, i); }).join('') +
    '</div>' +
    '<button class="btnSmall teal" onclick="addIntroSlide()" style="margin-top:10px">+ Slide toevoegen</button>' +
  '</div>';
}

function buildSlideRow(sl, i) {
  return '<div style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:14px;margin-bottom:10px" id="slide-' + i + '">' +
    '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">' +
      '<span style="font-size:12px;font-weight:500;color:var(--ink-mid)">Slide ' + (i + 1) + '</span>' +
      '<button class="btnSmall red" onclick="removeIntroSlide(' + i + ')">✕ Verwijderen</button>' +
    '</div>' +
    formRow('Titel', 'input', 'slide-title-' + i, sl.title || '', '', false, 'updateSlide(' + i + ')') +
    formRow('Omschrijving', 'textarea', 'slide-body-' + i, sl.body || '', '', false, 'updateSlide(' + i + ')') +
  '</div>';
}

function addIntroSlide() {
  var m = S.activeData.meta || {};
  S.activeData.intro.slides = S.activeData.intro.slides || [];
  S.activeData.intro.slides.push({ key: 'slide-' + Date.now(), title: m.title || '', body: '' });
  markDirty(); renderTab('intro');
}

function removeIntroSlide(i) {
  S.activeData.intro.slides.splice(i, 1);
  markDirty(); renderTab('intro');
}

function updateSlide(i) {
  var sl = S.activeData.intro.slides[i];
  var t = document.getElementById('slide-title-' + i);
  var b = document.getElementById('slide-body-' + i);
  if (t) sl.title = t.value;
  if (b) sl.body = b.value;
  markDirty();
}

// ── SAVE ──────────────────────────────────────────────────────
function collectEditorState() {
  var t = S.activeTab;
  if (t === 'algemeen') {
    var titleEl = document.getElementById('metaTitle');
    var accentEl = document.getElementById('metaAccentHex') || document.getElementById('metaAccent');
    if (titleEl) {
      S.activeData.meta.title = titleEl.value;
      var idx = S.sets.findIndex(function(s) { return s.id === S.activeId; });
      if (idx >= 0) S.sets[idx].title = titleEl.value;
    }
    if (accentEl) {
      S.activeData.meta.cssVars = S.activeData.meta.cssVars || {};
      S.activeData.meta.cssVars['--pk-set-accent'] = accentEl.value;
    }
  }
  if (t === 'uitleg') {
    var coverEl = document.getElementById('uitlegCover');
    if (coverEl) S.activeData.uitleg.cover = coverEl.value;
    (S.activeData.meta.themes || []).forEach(function(th) {
      var el = document.getElementById('uitleg-' + th.key);
      if (el) S.activeData.uitleg[th.key] = el.value;
    });
  }
}

function saveSet() {
  collectEditorState();
  var btn = document.getElementById('saveBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span>';

  var id = S.activeId;
  var d = S.activeData;
  var msg = 'Update set: ' + id;

  Promise.all([
    saveFile('sets/' + id + '/meta.json', d.meta, d.metaSha, msg).then(function(r) {
      d.metaSha = (r.content || {}).sha || d.metaSha;
    }),
    saveFile('sets/' + id + '/questions.json', d.questions, d.questionsSha, msg).then(function(r) {
      d.questionsSha = (r.content || {}).sha || d.questionsSha;
    }),
    saveFile('sets/' + id + '/uitleg.json', d.uitleg, d.uitlegSha, msg).then(function(r) {
      d.uitlegSha = (r.content || {}).sha || d.uitlegSha;
    }),
    saveFile('sets/' + id + '/intro.json', d.intro, d.introSha, msg).then(function(r) {
      d.introSha = (r.content || {}).sha || d.introSha;
    }),
    saveIndex(msg)
  ]).then(function() {
    S.dirty = false;
    btn.disabled = false;
    btn.innerHTML = 'Opslaan';
    toast('Opgeslagen ✓', 'green');
    renderSidebar();
  }).catch(function(e) {
    btn.disabled = false;
    btn.innerHTML = 'Opslaan';
    toast('Fout: ' + e.message, 'red');
  });
}

function saveIndex(msg) {
  S.indexData.sets = S.sets;
  return saveFile('sets/index.json', S.indexData, S.indexSha, msg || 'Update index').then(function(r) {
    S.indexSha = (r.content || {}).sha || S.indexSha;
  });
}

// ── NEW SET ───────────────────────────────────────────────────
function showNewSetModal() {
  showModal(
    '<h3>Nieuwe kaartenset</h3>' +
    '<p>Geef een ID (slug) en een naam voor de nieuwe set.</p>' +
    '<div class="field"><label>ID (slug)</label>' +
      '<input id="newSetId" type="text" placeholder="team-reflectie" class="formInput">' +
    '</div>' +
    '<div class="field"><label>Naam</label>' +
      '<input id="newSetTitle" type="text" placeholder="Team reflectie" class="formInput">' +
    '</div>' +
    '<div class="modalActions">' +
      '<button class="btnCancel" onclick="closeModal()">Annuleren</button>' +
      '<button class="btnConfirm" onclick="createNewSet()">Aanmaken</button>' +
    '</div>'
  );
}

function createNewSet() {
  var rawId = (document.getElementById('newSetId').value || '').trim();
  var title = (document.getElementById('newSetTitle').value || '').trim();
  if (!rawId || !title) { toast('Vul beide velden in', 'red'); return; }
  var id = rawId.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '').replace(/-+/g, '-');
  if (!id) { toast('Ongeldige ID', 'red'); return; }
  if (S.sets.find(function(s) { return s.id === id; })) { toast('Set bestaat al', 'red'); return; }

  closeModal();
  S.sets.push({ id: id, title: title });
  S.activeData = {
    meta: getDefaultMeta(id, title),
    questions: {},
    uitleg: { cover: '' },
    intro: { slides: [{ key: 'cover', title: title, body: '', img: 'cards/voorkant.svg', alt: title }], hint: '← →' }
  };
  S.activeId = id;
  S.dirty = true;
  renderSidebar();
  renderEditor();
  toast('Set aangemaakt — sla op om te bewaren');
}

function getDefaultMeta(id, title) {
  return {
    id: id,
    title: title || id,
    cover: 'voorkant.svg',
    viewerTemplate: 'classic',
    cssVars: { '--pk-set-accent': '#F3D7A3', '--pk-set-bg': '#FFFFFF', '--pk-set-card': 'rgba(255,255,255,1)' },
    backMode: 'mirror',
    ui: { menu: { showInfo: true, showShuffle: true, showAllSets: true }, sheet: { enabled: true, defaultMode: 'cards' }, index: { layout: 'hero-grid' }, themeCss: 'theme.css' },
    themes: []
  };
}

// ── DELETE ────────────────────────────────────────────────────
function confirmDelete() {
  var id = S.activeId;
  showModal(
    '<h3>Set verwijderen?</h3>' +
    '<p>Dit verwijdert <strong>' + esc(id) + '</strong> uit de index. De bestanden in <code>sets/' + esc(id) + '/</code> blijven op GitHub staan en moeten handmatig worden verwijderd.</p>' +
    '<div class="modalActions">' +
      '<button class="btnCancel" onclick="closeModal()">Annuleren</button>' +
      '<button class="btnConfirmRed" onclick="deleteSet()">Verwijderen</button>' +
    '</div>'
  );
}

function deleteSet() {
  closeModal();
  var id = S.activeId;
  S.sets = S.sets.filter(function(s) { return s.id !== id; });
  if (S.indexData.default === id && S.sets.length) S.indexData.default = S.sets[0].id;
  saveIndex('Remove set: ' + id).then(function() {
    S.activeId = null;
    renderSidebar();
    document.getElementById('mainContent').innerHTML =
      '<div class="welcome"><h2>Set verwijderd</h2><p>Selecteer een andere set of maak een nieuwe aan.</p></div>';
    toast('Set verwijderd uit index', 'green');
  }).catch(function(e) { toast('Fout: ' + e.message, 'red'); });
}

// ── HELPERS ───────────────────────────────────────────────────
function formRow(label, type, id, value, placeholder, readonly, extraAttr) {
  var html = '<div class="formRow">' +
    '<label class="formLabel">' + esc(label) + '</label>';
  if (type === 'color') {
    html += '<div class="colorRow">' +
      '<input type="color" id="' + id + '" value="' + esc(value) + '">' +
      '<input type="text" class="formInput" id="' + id + 'Hex" value="' + esc(value) + '" placeholder="#F3D7A3">' +
    '</div>';
  } else if (type === 'textarea') {
    html += '<textarea class="formTextarea" id="' + id + '"' +
      (extraAttr ? ' oninput="' + extraAttr + '"' : '') + '>' + esc(value) + '</textarea>';
  } else {
    html += '<input type="text" class="formInput" id="' + id + '"' +
      (placeholder ? ' placeholder="' + esc(placeholder) + '"' : '') +
      (readonly ? ' readonly style="opacity:0.6"' : '') +
      (extraAttr ? ' oninput="' + extraAttr + '"' : '') +
      ' value="' + esc(value) + '">';
  }
  if (placeholder && type === 'input' && !readonly)
    html += '<div class="formHint">' + esc(placeholder) + '</div>';
  html += '</div>';
  return html;
}

function markDirty() { S.dirty = true; }

function esc(s) {
  return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

function show(id) { document.getElementById(id).classList.remove('hidden'); }
function hide(id) { document.getElementById(id).classList.add('hidden'); }

function tryParse(s) { try { return JSON.parse(s); } catch(_) { return null; } }

// Toast
var toastT;
function toast(msg, type) {
  var el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'toast show' + (type ? ' ' + type : '');
  clearTimeout(toastT);
  toastT = setTimeout(function() { el.className = 'toast'; }, 3000);
}

// Modal
function showModal(html) {
  document.getElementById('modalContent').innerHTML = html;
  document.getElementById('modalOverlay').classList.remove('hidden');
}
function closeModal() {
  document.getElementById('modalOverlay').classList.add('hidden');
}

// Enter key on setup
document.addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && !document.getElementById('setupScreen').classList.contains('hidden')) {
    connectGitHub();
  }
});


