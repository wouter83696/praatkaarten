// Accent color presets — add more swatches here freely
var COLOR_PRESETS = [
  { name: 'Warm zand',    accent: '#F3D7A3', bg: '#FFFFFF', card: 'rgba(255,255,255,1)' },
  { name: 'Mintgroen',    accent: '#7fcfc9', bg: '#F7FDFB', card: 'rgba(255,255,255,1)' },
  { name: 'Lavendel',     accent: '#A89BD4', bg: '#FAF9FF', card: 'rgba(255,255,255,1)' },
  { name: 'Terracotta',   accent: '#D4845A', bg: '#FFF8F5', card: 'rgba(255,255,255,1)' },
  { name: 'Saliegroen',   accent: '#8AB89A', bg: '#F7FBF8', card: 'rgba(255,255,255,1)' },
  { name: 'Leisteenblauw',accent: '#6B8EAD', bg: '#F5F8FA', card: 'rgba(255,255,255,1)' },
  { name: 'Rozé',         accent: '#D4929E', bg: '#FFF7F8', card: 'rgba(255,255,255,1)' },
];

function buildStijl() {
  var m = S.activeData.meta || {};
  var curLayout = ((m.ui || {}).index || {}).layout || 'carousel';
  var curViewer = m.viewerTemplate || 'classic';
  var curAccent = (m.cssVars || {})['--pk-set-accent'] || '#F3D7A3';

  var html = '<div class="panel">';

  // ── Index layout
  html += '<div class="templateSectionLabel">Indexpagina — lay-out</div>';
  html += '<div class="templateGrid">';
  LAYOUT_TEMPLATES.forEach(function(tpl) {
    var sel = curLayout === tpl.id ? ' selected' : '';
    html += '<div class="templateCard' + sel + '" onclick="pickLayout(\'' + tpl.id + '\')">' +
      '<div class="templateBadge">✓</div>' +
      '<div class="templateThumb">' + tpl.thumb + '</div>' +
      '<div class="templateInfo">' +
        '<div class="templateName">' + esc(tpl.name) + '</div>' +
        '<div class="templateDesc">' + esc(tpl.desc) + '</div>' +
      '</div>' +
    '</div>';
  });
  html += '</div>';

  // ── Viewer template
  html += '<div class="templateSectionLabel" style="margin-top:24px">Kaartenviewer — weergave</div>';
  html += '<div class="templateGrid">';
  VIEWER_TEMPLATES.forEach(function(tpl) {
    var sel = curViewer === tpl.id ? ' selected' : '';
    html += '<div class="templateCard' + sel + '" onclick="pickViewer(\'' + tpl.id + '\')">' +
      '<div class="templateBadge">✓</div>' +
      '<div class="templateThumb">' + tpl.thumb + '</div>' +
      '<div class="templateInfo">' +
        '<div class="templateName">' + esc(tpl.name) + '</div>' +
        '<div class="templateDesc">' + esc(tpl.desc) + '</div>' +
      '</div>' +
    '</div>';
  });
  html += '</div>';

  // ── Kleur
  html += '<div class="templateSectionLabel" style="margin-top:24px">Accentkleur</div>';
  html += '<div class="colorRow2">';
  COLOR_PRESETS.forEach(function(p, i) {
    var sel = curAccent.toLowerCase() === p.accent.toLowerCase() ? ' selected' : '';
    html += '<div class="colorSwatch' + sel + '" title="' + esc(p.name) + '" ' +
      'style="background:' + esc(p.accent) + '" ' +
      'onclick="pickColorPreset(' + i + ')"></div>';
  });
  html += '</div>';
  html += '<div class="colorPickerRow">' +
    '<label>Eigen kleur:</label>' +
    '<input type="color" id="stijlColorPicker" value="' + esc(curAccent) + '" oninput="pickCustomColor(this.value)">' +
    '<input type="text" class="formInput" style="width:100px" id="stijlColorHex" value="' + esc(curAccent) + '" ' +
      'oninput="onStijlHexInput(this.value)">' +
  '</div>';

  html += '<p class="formHint" style="margin-top:8px">Sla op om de wijzigingen op GitHub te zetten.</p>';
  html += '</div>';
  return html;
}

function pickLayout(id) {
  var m = S.activeData.meta;
  m.ui = m.ui || {};
  var tpl = LAYOUT_TEMPLATES.find(function(t) { return t.id === id; });
  if (tpl) tpl.setLayout(m);
  markDirty();
  renderTab('stijl');
}

function pickViewer(id) {
  S.activeData.meta.viewerTemplate = id;
  markDirty();
  renderTab('stijl');
}

function pickColorPreset(i) {
  var p = COLOR_PRESETS[i];
  S.activeData.meta.cssVars = S.activeData.meta.cssVars || {};
  S.activeData.meta.cssVars['--pk-set-accent'] = p.accent;
  S.activeData.meta.cssVars['--pk-set-bg'] = p.bg;
  S.activeData.meta.cssVars['--pk-set-card'] = p.card;
  markDirty();
  renderTab('stijl');
}

function onStijlHexInput(val) {
  if (/^#[0-9a-fA-F]{6}$/.test(val)) {
    var picker = document.getElementById('stijlColorPicker');
    if (picker) picker.value = val;
    pickCustomColor(val);
  }
}

function pickCustomColor(val) {
  S.activeData.meta.cssVars = S.activeData.meta.cssVars || {};
  S.activeData.meta.cssVars['--pk-set-accent'] = val;
  var hexEl = document.getElementById('stijlColorHex');
  if (hexEl && hexEl !== document.activeElement) hexEl.value = val;
  markDirty();
  // Update swatches without full re-render
  document.querySelectorAll('.colorSwatch').forEach(function(sw) {
    sw.classList.remove('selected');
  });
}

// ── KAARTEN TAB ──────────────────────────────────────────────
// Cache: { 'sets/id/cards/x.svg': { sha, dataUrl } }


var cardCache = {};
var knownFiles = {}; // sets/id/cards => [filename, ...]


function buildKaarten() {
  var themes = S.activeData.meta.themes || [];
  var id = S.activeId;

  // Cover entry + one entry per theme, including their .card filename
  var allCards = [{ key: 'voorkant', label: 'Cover', cardFile: 'voorkant.svg', iscover: true }].concat(
    themes.map(function(t) {
      return { key: t.key, label: t.label || t.key, cardFile: t.card || (t.key + '.svg'), themeIndex: themes.indexOf(t) };
    })
  );

  var html = '<div class="panel">' +
    '<p class="cardSectionSub">Upload afbeeldingen en koppel ze aan een thema. ' +
    'Klik <strong>Koppel</strong> om een ander bestand te kiezen. ' +
    'Sleep of klik een tegel om een nieuw SVG te uploaden.</p>';

  ['cards', 'cards_rect'].forEach(function(folder) {
    html += '<div style="margin-bottom:28px">' +
      '<div style="font-size:13px;font-weight:600;margin-bottom:12px;color:var(--ink)">' +
        (folder === 'cards' ? '🃏 cards/ — liggende kaarten' : '📎 cards_rect/ — staande thumbnails (menu)') +
      '</div>' +
      '<div class="cardGrid" id="grid-' + folder + '">';

    allCards.forEach(function(card) {
      var path = 'sets/' + id + '/' + folder + '/' + card.cardFile;
      var cached = cardCache[path];
      html += buildCardTile(card, folder, path, cached);
    });

    html += '</div></div>';
  });

  html += '</div>';
  return html;
}

function buildCardTile(card, folder, path, cached) {
  var safeId = btoa(path).replace(/[^a-zA-Z0-9]/g,'').slice(0,20);
  var cardFile = path.split('/').pop();

  var previewHtml;
  if (cached && cached.dataUrl) {
    previewHtml = '<div class="cardPreview"><img src="' + cached.dataUrl + '" alt="' + esc(card.label) + '"></div>';
  } else {
    previewHtml = '<div class="cardPreview">' +
      '<div class="cardPreviewEmpty">' +
        '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">' +
          '<rect x="3" y="3" width="18" height="18" rx="3"/><path d="M3 9l4-4 4 4 4-6 6 8"/>' +
        '</svg>' +
        '<span>Klik om te uploaden</span>' +
      '</div>' +
    '</div>';
  }

  // Link badge: shows which file is linked, only for theme cards (not cover)
  var linkHtml = '';
  if (!card.iscover) {
    linkHtml = '<div class="cardTileLinked">' +
      '<span class="cardLinkBadge" title="Gekoppeld bestand">' + esc(cardFile) + '</span>' +
    '</div>';
  }

  // Bottom label row
  var labelHtml = '<div class="cardTileLabel">' +
    '<span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + esc(card.label) + '</span>';

  // Koppel-knop: only for theme cards, not cover
  if (!card.iscover && typeof card.themeIndex === 'number') {
    labelHtml += '<button class="cardLinkBtn" ' +
      'data-themeindex="' + card.themeIndex + '" ' +
      'data-folder="' + folder + '" ' +
      'data-currentfile="' + esc(cardFile) + '" ' +
      'data-action="link">Koppel</button>';
  } else {
    labelHtml += '<span class="cardUploadBtn">SVG</span>';
  }

  labelHtml += '</div>';

  return '<div class="cardTile" id="tile-' + safeId + '" data-path="' + esc(path) + '" data-safeid="' + safeId + '">' +
    previewHtml +
    linkHtml +
    labelHtml +
    '<input type="file" id="file-' + safeId + '" accept=".svg,image/svg+xml,.png,image/png" data-path="' + esc(path) + '" data-safeid="' + safeId + '">' +
  '</div>';
}

function triggerFileInput(safeId) {
  var input = document.getElementById('file-' + safeId);
  if (input) input.click();
}

function handleFileInput(input) {
  var path = input.dataset.path;
  var safeId = input.dataset.safeid;
  var file = input.files && input.files[0];
  if (!file) return;
  uploadSvgFile(file, path, safeId);
  input.value = '';
}

function handleDrop(ev, path, safeId) {
  ev.preventDefault();
  var tile = document.getElementById('tile-' + safeId);
  if (tile) tile.style.borderColor = '';
  var file = ev.dataTransfer && ev.dataTransfer.files && ev.dataTransfer.files[0];
  if (!file) return;
  if (!file.name.endsWith('.svg') && file.type !== 'image/svg+xml') {
    toast('Alleen SVG-bestanden', 'red'); return;
  }
  uploadSvgFile(file, path, safeId);
}

function uploadSvgFile(file, path, safeId) {
  var tile = document.getElementById('tile-' + safeId);
  if (tile) {
    tile.innerHTML += '<div class="cardUploading"><span class="spinner" style="border-color:rgba(79,142,158,0.3);border-top-color:var(--teal)"></span> Uploaden…</div>';
  }

  var reader = new FileReader();
  reader.onload = function(e) {
    var svgText = e.target.result;
    var dataUrl = 'data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(svgText)));
    var b64Content = btoa(unescape(encodeURIComponent(svgText)));

    // Get current sha if exists
    var existingSha = cardCache[path] ? cardCache[path].sha : null;

    var body = {
      message: 'Upload kaart: ' + path.split('/').pop(),
      content: b64Content
    };
    if (existingSha) body.sha = existingSha;

    api('/contents/' + path, 'PUT', body).then(function(res) {
      var newSha = res.content ? res.content.sha : null;
      cardCache[path] = { sha: newSha, dataUrl: dataUrl };
      toast('✓ ' + path.split('/').pop() + ' opgeslagen', 'green');
      // Re-render just this tile
      if (tile) {
        var parts = path.split('/');
        var folder = parts[parts.length - 2];
        var key = parts[parts.length - 1].replace('.svg', '');
        var themes = S.activeData.meta.themes || [];
        var cardMeta = { key: key, label: key === 'voorkant' ? 'Cover' : (themes.find(function(t){ return t.key === key; }) || {}).label || key };
        tile.outerHTML = buildCardTile(cardMeta, folder, path, cardCache[path]);
      }
    }).catch(function(err) {
      toast('Fout: ' + err.message, 'red');
      var loading = tile ? tile.querySelector('.cardUploading') : null;
      if (loading) loading.remove();
    });
  };
  reader.readAsText(file);
}

// ── CARD LINKING ──────────────────────────────────────────────

// List all files in a folder (e.g. sets/id/cards/)
function listFolderFiles(folderPath) {
  if (knownFiles[folderPath]) return Promise.resolve(knownFiles[folderPath]);
  return api('/contents/' + folderPath).then(function(res) {
    var files = Array.isArray(res) ? res
      .filter(function(f) { return f.type === 'file' && (f.name.endsWith('.svg') || f.name.endsWith('.png')); })
      .map(function(f) { return { name: f.name, sha: f.sha }; }) : [];
    knownFiles[folderPath] = files;
    return files;
  }).catch(function() { return []; });
}

var _linkPopupEl = null;

function closeLinkPopup() {
  if (_linkPopupEl) { _linkPopupEl.remove(); _linkPopupEl = null; }
  document.removeEventListener('click', closeLinkPopupOnOutside);
}

function closeLinkPopupOnOutside(ev) {
  if (_linkPopupEl && !_linkPopupEl.contains(ev.target)) closeLinkPopup();
}

function openLinkPopup(ev, themeIndex, folder) {
  closeLinkPopup();
  var id = S.activeId;
  var theme = S.activeData.meta.themes[themeIndex];
  if (!theme) return;
  var currentFile = theme.card || (theme.key + '.svg');
  var folderPath = 'sets/' + id + '/' + folder;

  // Build popup
  var popup = document.createElement('div');
  popup.className = 'linkPopup';
  popup.innerHTML = '<div class="linkPopupTitle">Koppel kaart: ' + esc(theme.label || theme.key) + '</div>' +
    '<div class="linkPopupList" id="linkPopupList"><div style="color:var(--ink-soft);font-size:12px;padding:6px">Laden…</div></div>' +
    '<div class="linkPopupActions">' +
      '<label class="btnSmall teal" style="cursor:pointer">' +
        '<input type="file" style="display:none" data-themeindex="' + themeIndex + '" data-folder="' + folder + '" data-action="uploadlink" accept=".svg,.png">' +
        '+ Nieuw uploaden' +
      '</label>' +
    '</div>';

  // Position near button
  var rect = ev.target.getBoundingClientRect();
  popup.style.top = (rect.bottom + 6 + window.scrollY) + 'px';
  popup.style.left = Math.max(8, rect.left - 100) + 'px';
  document.body.appendChild(popup);
  _linkPopupEl = popup;

  // Load file list
  listFolderFiles(folderPath).then(function(files) {
    var list = document.getElementById('linkPopupList');
    if (!list) return;
    if (!files.length) {
      list.innerHTML = '<div style="color:var(--ink-soft);font-size:12px;padding:6px">Nog geen bestanden geüpload.</div>';
      return;
    }
    list.innerHTML = files.map(function(f) {
      var isActive = f.name === currentFile;
      var cachedPath = folderPath + '/' + f.name;
      var thumb = cardCache[cachedPath] && cardCache[cachedPath].dataUrl
        ? '<img src="' + cardCache[cachedPath].dataUrl + '">'
        : '';
      return '<button class="linkPopupItem' + (isActive ? ' active' : '') + '" ' +
        'data-themeindex="' + themeIndex + '" data-folder="' + folder + '" data-file="' + esc(f.name) + '" ' +
      '<button class="linkPopupItem' + (isActive ? ' active' : '') + '" ' +
        'data-action="linkcard" data-themeindex="' + themeIndex + '" data-folder="' + folder + '" data-file="' + esc(f.name) + '">' +
        '<div class="linkPopupThumb">' + thumb + '</div>' +
        '<span class="linkPopupName">' + esc(f.name) + '</span>' +
        (isActive ? '<span style="color:var(--teal);font-size:11px">✓</span>' : '') +
      '</button>';
    }).join('');
  });

  setTimeout(function() {
    document.addEventListener('click', closeLinkPopupOnOutside);
  }, 10);
}

function linkThemeCard(themeIndex, folder, filename) {
  var theme = S.activeData.meta.themes[themeIndex];
  if (!theme) return;
  theme.card = filename;
  markDirty();
  closeLinkPopup();
  // Re-render the card tile for this theme
  renderTab('kaarten');
  setTimeout(loadCardPreviews, 50);
  toast('Kaart gekoppeld aan ' + (theme.label || theme.key));
}

function uploadAndLinkCard(input, themeIndex, folder) {
  var file = input.files && input.files[0];
  if (!file) return;
  var theme = S.activeData.meta.themes[themeIndex];
  var id = S.activeId;
  var filename = file.name.replace(/[^a-zA-Z0-9._-]/g, '-');
  var path = 'sets/' + id + '/' + folder + '/' + filename;

  closeLinkPopup();

  var reader = new FileReader();
  reader.onload = function(e) {
    var text = e.target.result;
    var isBinary = file.name.endsWith('.png');
    var b64 = isBinary
      ? btoa(text)  // png: readAsBinaryString
      : btoa(unescape(encodeURIComponent(text)));
    var dataUrl = isBinary
      ? 'data:image/png;base64,' + b64
      : 'data:image/svg+xml;base64,' + b64;

    var existingSha = cardCache[path] ? cardCache[path].sha : null;
    var body = { message: 'Upload: ' + filename, content: b64 };
    if (existingSha) body.sha = existingSha;

    api('/contents/' + path, 'PUT', body).then(function(res) {
      var sha = res.content ? res.content.sha : null;
      cardCache[path] = { sha: sha, dataUrl: dataUrl };
      // Invalidate folder file list so it reloads
      delete knownFiles['sets/' + id + '/' + folder];
      // Link it
      if (theme) theme.card = filename;
      markDirty();
      renderTab('kaarten');
      setTimeout(loadCardPreviews, 50);
      toast('Geüpload en gekoppeld: ' + filename, 'green');
    }).catch(function(err) { toast('Fout: ' + err.message, 'red'); });
  };
  if (file.name.endsWith('.png')) {
    reader.readAsBinaryString(file);
  } else {
    reader.readAsText(file);
  }
  input.value = '';
}

// Load card previews from GitHub when kaarten tab opens
function loadCardPreviews() {
  var id = S.activeId;
  var themes = S.activeData.meta.themes || [];
  // Collect all unique filenames to load (cover + each theme's .card file)
  var toLoad = [{ folder: 'cards', file: 'voorkant.svg' }, { folder: 'cards_rect', file: 'voorkant.svg' }];
  themes.forEach(function(t) {
    var f = t.card || (t.key + '.svg');
    toLoad.push({ folder: 'cards', file: f });
    toLoad.push({ folder: 'cards_rect', file: f });
  });
  // Deduplicate
  var seen = {};
  toLoad = toLoad.filter(function(x) {
    var k = x.folder + '/' + x.file;
    if (seen[k]) return false; seen[k] = true; return true;
  });
  toLoad.forEach(function(item) {
    var path = 'sets/' + id + '/' + item.folder + '/' + item.file;
    if (cardCache[path]) return;
    var isSvg = item.file.endsWith('.svg');
    api('/contents/' + path).then(function(res) {
        var raw = atob(res.content.replace(/\s/g, ''));
        var dataUrl = isSvg
          ? 'data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(raw)))
          : 'data:image/png;base64,' + res.content.replace(/\s/g, '');
        cardCache[path] = { sha: res.sha, dataUrl: dataUrl };
        // Update preview in DOM
        var safeId = btoa(path).replace(/[^a-zA-Z0-9]/g,'').slice(0,20);
        var tile = document.getElementById('tile-' + safeId);
        if (tile) {
          var preview = tile.querySelector('.cardPreview, .cardPreviewEmpty');
          if (preview) {
            var newDiv = document.createElement('div');
            newDiv.className = 'cardPreview';
            newDiv.innerHTML = '<img src="' + dataUrl + '" alt="">';
            preview.replaceWith(newDiv);
          }
        }
      }).catch(function() {
        // File doesn't exist yet — that's fine
      });
  });
}

// Event delegation for card tiles (click to upload, drag to drop)
document.addEventListener('click', function(ev) {
  // Koppel button
  var linkBtn = ev.target.closest('[data-action="link"]');
  if (linkBtn) {
    ev.stopPropagation();
    var ti = parseInt(linkBtn.dataset.themeindex, 10);
    var folder = linkBtn.dataset.folder;
    openLinkPopup(ev, ti, folder);
    return;
  }
  // Link popup item click
  var linkItem = ev.target.closest('[data-action="linkcard"]');
  if (linkItem) {
    ev.stopPropagation();
    var ti2 = parseInt(linkItem.dataset.themeindex, 10);
    var folder2 = linkItem.dataset.folder;
    var file2 = linkItem.dataset.file;
    linkThemeCard(ti2, folder2, file2);
    return;
  }
  // Card tile click-to-upload (not on buttons)
  if (ev.target.closest('button') || ev.target.closest('label')) return;
  var tile = ev.target.closest('.cardTile');
  if (!tile) return;
  var safeId = tile.dataset.safeid;
  if (safeId) triggerFileInput(safeId);
});

document.addEventListener('change', function(ev) {
  if (ev.target.type !== 'file') return;
  if (ev.target.dataset.action === 'uploadlink') {
    var ti = parseInt(ev.target.dataset.themeindex, 10);
    var folder = ev.target.dataset.folder;
    uploadAndLinkCard(ev.target, ti, folder);
    return;
  }
  if (ev.target.dataset.path) {
    handleFileInput(ev.target);
  }
});

document.addEventListener('dragover', function(ev) {
  var tile = ev.target.closest('.cardTile');
  if (tile) { ev.preventDefault(); tile.style.borderColor = 'var(--teal)'; }
});

document.addEventListener('dragleave', function(ev) {
  var tile = ev.target.closest('.cardTile');
  if (tile && !tile.contains(ev.relatedTarget)) tile.style.borderColor = '';
});

document.addEventListener('drop', function(ev) {
  var tile = ev.target.closest('.cardTile');
  if (!tile) return;
  ev.preventDefault();
  tile.style.borderColor = '';
  var path = tile.dataset.path;
  var safeId = tile.dataset.safeid;
  if (!path || !safeId) return;
  var file = ev.dataTransfer && ev.dataTransfer.files && ev.dataTransfer.files[0];
  if (!file) return;
  if (!file.name.endsWith('.svg') && file.type !== 'image/svg+xml') {
    toast('Alleen SVG-bestanden', 'red'); return;
  }
  uploadSvgFile(file, path, safeId);
});

// Patch switchTab to load previews when kaarten tab selected
var _origSwitchTab = switchTab;
switchTab = function(t) {
  _origSwitchTab(t);
  if (t === 'kaarten') {
    setTimeout(loadCardPreviews, 100);
  }
};
</script>
</body>
</html>
